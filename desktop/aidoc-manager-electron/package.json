{
  "name": "haobanfa-aidoc-manager",
  "version": "1.0.2",
  "description": "好办法 AI 档案管理桌面端",
  "main": "electron/main.js",
  "author": "好办法",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "node electron/dev-runner.mjs",
    "build": "vite build",
    "build:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-backend.ps1",
    "prepare:electron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-electron-runtime.ps1",
    "dist:win": "npm run build && npm run build:backend && npm run prepare:electron && electron-builder --win nsis",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "lucide-vue-next": "^0.468.0",
    "vite": "^6.0.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "online.haobanfa.aidoc",
    "productName": "好办法AI档案管理",
    "copyright": "Copyright © 2026 好办法",
    "electronDist": "build/electron-runtime",
    "disableAsarIntegrity": true,
    "directories": {
      "output": "package-output",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/backend-dist/aidoc-backend",
        "to": "backend"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "好办法AI档案管理-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "好办法AI档案管理",
      "deleteAppDataOnUninstall": false
    }
  }
}
